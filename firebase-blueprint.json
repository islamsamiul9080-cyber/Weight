{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Media": {
      "title": "Transformation Media",
      "description": "Images and videos of weight loss journeys",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video"] },
        "url": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "url", "title", "uploadedBy"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "media/{mediaId}": {
      "schema": "Media",
      "description": "Collection of transformation media"
    },
    "library/{itemId}": {
      "schema": "Media",
      "description": "Collection of library assets (exercises, images, shorts)"
    }
  }
}
